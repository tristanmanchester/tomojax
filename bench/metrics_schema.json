{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tomojax/bench/metrics.schema.json",
  "title": "TomoJAX benchmark metrics",
  "type": "object",
  "required": [
    "profile",
    "success",
    "objective_name",
    "objective_direction",
    "objective_value",
    "quality",
    "device",
    "oom",
    "error"
  ],
  "properties": {
    "profile": {"type": "string"},
    "success": {"type": "boolean"},
    "objective_name": {"type": "string"},
    "objective_direction": {"type": "string", "enum": ["minimise", "maximize", "maximise"]},
    "objective_value": {"type": ["number", "null"]},
    "warmup_seconds": {"type": ["number", "null"]},
    "warmup_incomplete": {"type": ["boolean", "null"]},
    "primer_ran": {"type": ["boolean", "null"]},
    "primer_seconds": {"type": ["number", "null"]},
    "primer_reached_finest_level": {"type": ["boolean", "null"]},
    "first_run_seconds": {"type": ["number", "null"]},
    "warm_run_seconds_mean": {"type": ["number", "null"]},
    "warm_run_seconds_std": {"type": ["number", "null"]},
    "warmup_peak_gpu_memory_mb": {"type": ["number", "null"]},
    "primer_peak_gpu_memory_mb": {"type": ["number", "null"]},
    "peak_gpu_memory_mb": {"type": ["number", "null"]},
    "warmup_peak_gpu_memory_process_mb": {"type": ["number", "null"]},
    "primer_peak_gpu_memory_process_mb": {"type": ["number", "null"]},
    "peak_gpu_memory_process_mb": {"type": ["number", "null"]},
    "warmup_peak_gpu_memory_device_mb": {"type": ["number", "null"]},
    "primer_peak_gpu_memory_device_mb": {"type": ["number", "null"]},
    "peak_gpu_memory_device_mb": {"type": ["number", "null"]},
    "warmup_peak_host_rss_mb": {"type": ["number", "null"]},
    "primer_peak_host_rss_mb": {"type": ["number", "null"]},
    "peak_host_rss_mb": {"type": ["number", "null"]},
    "gpu_memory_backend": {"type": ["string", "null"]},
    "gpu_memory_scope": {"type": ["string", "null"]},
    "gpu_memory_process_source": {"type": ["string", "null"]},
    "gpu_memory_process_supported": {"type": ["boolean", "null"]},
    "gpu_memory_sample_interval_seconds": {"type": ["number", "null"]},
    "gpu_memory_sample_count": {"type": ["integer", "null"]},
    "gpu_memory_observed_gpu_count": {"type": ["integer", "null"]},
    "gpu_sampler_error": {"type": ["string", "null"]},
    "jax_device_memory_profile_path": {"type": ["string", "null"]},
    "jax_device_memory_profile_error": {"type": ["string", "null"]},
    "summary_image_path": {"type": ["string", "null"]},
    "summary_image_error": {"type": ["string", "null"]},
    "quality_threshold_metric": {"type": ["string", "null"]},
    "quality_threshold_value": {"type": ["number", "null"]},
    "quality_threshold_met": {"type": ["boolean", "null"]},
    "warmup_reached_finest_level": {"type": ["boolean", "null"]},
    "warmup_stop_reason": {"type": ["string", "null"]},
    "required_warm_successes": {"type": ["integer", "null"]},
    "warm_threshold_hit_count": {"type": ["integer", "null"]},
    "warm_threshold_total_runs": {"type": ["integer", "null"]},
    "warm_threshold_success_rate": {"type": ["number", "null"]},
    "stopped_on_threshold": {"type": ["boolean", "null"]},
    "stopped_on_plateau": {"type": ["boolean", "null"]},
    "stopped_on_budget": {"type": ["boolean", "null"]},
    "warm_stopped_on_threshold_count": {"type": ["integer", "null"]},
    "warm_stopped_on_plateau_count": {"type": ["integer", "null"]},
    "warm_stopped_on_budget_count": {"type": ["integer", "null"]},
    "reached_finest_level": {"type": ["boolean", "null"]},
    "finest_level_first_elapsed_seconds": {"type": ["number", "null"]},
    "finest_level_first_outer_idx": {"type": ["integer", "null"]},
    "warm_reached_finest_level_count": {"type": ["integer", "null"]},
    "benchmark_valid": {"type": ["boolean", "null"]},
    "invalid_reason": {"type": ["string", "null"]},
    "final_stop_reason": {"type": ["string", "null"]},
    "final_stop_level_factor": {"type": ["integer", "null"]},
    "first_threshold_crossing_level_factor": {"type": ["integer", "null"]},
    "cold_seconds_to_quality_threshold": {"type": ["number", "null"]},
    "warm_seconds_to_quality_threshold": {"type": ["number", "null"]},
    "cold_outer_iters_to_quality_threshold": {"type": ["integer", "null"]},
    "warm_outer_iters_to_quality_threshold": {"type": ["integer", "null"]},
    "best_quality_value": {"type": ["number", "null"]},
    "best_quality_elapsed_seconds": {"type": ["number", "null"]},
    "total_outer_iters_executed": {"type": ["integer", "null"]},
    "cold_convergence_trace": {"type": "array"},
    "warm_convergence_trace": {"type": "array"},
    "warm_convergence_traces": {"type": "array"},
    "quality": {"type": "object"},
    "device": {"type": "object"},
    "oom": {"type": "boolean"},
    "error": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
