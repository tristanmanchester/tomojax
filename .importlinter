[importlinter]
root_package = tomojax

[importlinter:contract:layers]
name = Layer direction
type = layers
layers =
    tomojax.cli
    tomojax.bench
    tomojax.align
    tomojax.verify
    tomojax.datasets
    tomojax.io
    tomojax.data
    tomojax.recon
    tomojax.forward
    tomojax.backends
    tomojax.nuisance
    tomojax.calibration
    tomojax.motion
    tomojax.geometry
    tomojax.core

[importlinter:contract:production-no-data]
name = Production modules avoid lower-level data package
type = forbidden
allow_indirect_imports = True
source_modules =
    tomojax.align
    tomojax.backends
    tomojax.calibration
    tomojax.cli
    tomojax.core
    tomojax.forward
    tomojax.geometry
    tomojax.motion
    tomojax.nuisance
    tomojax.recon
    tomojax.verify
forbidden_modules =
    tomojax.data
